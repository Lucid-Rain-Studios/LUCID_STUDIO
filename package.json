{
  "name": "lucid-git",
  "version": "0.1.16",
  "description": "Git client for game development teams",
  "author": "Lucid Rain Studios",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "tsc -p tsconfig.main.json && concurrently -k \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "tsc -p tsconfig.main.json && vite build",
    "package": "npm run build && electron-builder",
    "release": "npm run build && electron-builder --publish always",
    "release:patch": "npm version patch && npm run release",
    "release:minor": "npm version minor && npm run release",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src electron"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.6.0",
    "@tanstack/react-query": "^5.59.0",
    "@tanstack/react-virtual": "^3.10.0",
    "@types/d3-force": "^3.0.10",
    "better-sqlite3": "^11.0.0",
    "chokidar": "^3.6.0",
    "clsx": "^2.1.0",
    "cmdk": "^1.0.0",
    "d3-force": "^3.0.0",
    "date-fns": "^4.1.0",
    "dugite": "^1.91.0",
    "electron-store": "^10.0.0",
    "electron-updater": "^6.3.0",
    "keytar": "^7.9.0",
    "lucide-react": "^0.454.0",
    "p-queue": "^8.0.1",
    "playwright": "^1.59.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "recharts": "^2.13.0",
    "sharp": "^0.34.5",
    "tailwind-merge": "^2.5.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.48.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^9.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^5.4.0",
    "wait-on": "^8.0.0"
  },
  "keywords": [],
  "license": "ISC"
}
